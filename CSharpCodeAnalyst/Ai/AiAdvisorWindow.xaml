<Window x:Class="CSharpCodeAnalyst.Ai.AiAdvisorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Advisor"
        Height="600" Width="700"
        MinHeight="300" MinWidth="400"
        WindowStartupLocation="Manual">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="ResponseTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     FontFamily="Segoe UI"
                     FontSize="13"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Disabled"
                     Background="Transparent"
                     BorderThickness="0" />
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button Content="Close" Width="75" Click="CloseButton_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
