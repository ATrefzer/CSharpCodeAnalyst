<Window x:Class="CSharpCodeAnalyst.Features.History.ImportHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:history="clr-namespace:CSharpCodeAnalyst.Features.History"
        xmlns:resources="clr-namespace:CSharpCodeAnalyst.Resources"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance history:ImportHistoryDialogViewModel}"
        Title="{x:Static resources:Strings.History_ImportDialog_Title}" Width="520"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        MinWidth="420"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="15" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="15" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Explanatory text -->
        <TextBlock Grid.Row="0"
                   Text="{Binding Description}"
                   TextWrapping="Wrap" />

        <!-- Repository root -->
        <TextBlock Grid.Row="2" Text="{x:Static resources:Strings.History_RepositoryPath_Label}" Margin="0,0,0,5" />
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     x:Name="RepositoryPathTextBox"
                     Text="{Binding RepositoryPath, UpdateSourceTrigger=PropertyChanged}"
                     Height="25"
                     VerticalContentAlignment="Center" />
            <Button Grid.Column="1"
                    Content="..."
                    Width="30"
                    Height="25"
                    Margin="2,0,0,0"
                    Click="BrowseRepository_Click" />
        </Grid>
        <TextBlock Grid.Row="4"
                   Text="{Binding RepositoryPathError}"
                   Foreground="Red"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,3,0,0" />

        <!-- Output file -->
        <TextBlock Grid.Row="6" Text="{x:Static resources:Strings.History_OutputFilePath_Label}" Margin="0,0,0,5" />
        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     x:Name="OutputFilePathTextBox"
                     Text="{Binding OutputFilePath, UpdateSourceTrigger=PropertyChanged}"
                     LostFocus="OutputFilePathTextBox_LostFocus"
                     Height="25"
                     VerticalContentAlignment="Center" />
            <Button Grid.Column="1"
                    Content="..."
                    Width="30"
                    Height="25"
                    Margin="2,0,0,0"
                    Click="BrowseOutputFile_Click" />
        </Grid>
        <TextBlock Grid.Row="8"
                   Text="{Binding OutputFilePathError}"
                   Foreground="Red"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,3,0,0" />

        <!-- Buttons -->
        <StackPanel Grid.Row="10"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{x:Static resources:Strings.History_OkButton}"
                    Width="75"
                    Click="OkButton_Click"
                    IsEnabled="{Binding CanAccept}"
                    IsDefault="True"
                    Margin="0,0,10,0" />
            <Button Content="{x:Static resources:Strings.History_CancelButton}"
                    Width="75"
                    Click="CancelButton_Click"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
