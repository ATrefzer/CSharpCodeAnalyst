<Window x:Class="CSharpCodeAnalyst.Features.History.EditAliasDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:history="clr-namespace:CSharpCodeAnalyst.Features.History"
        xmlns:resources="clr-namespace:CSharpCodeAnalyst.Resources"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance history:EditAliasDialogViewModel}"
        Title="{x:Static resources:Strings.EditAlias_Title}"
        Width="480" Height="540"
        MinWidth="380" MinHeight="320"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="15" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{x:Static resources:Strings.EditAlias_Description}"
                   TextWrapping="Wrap" />

        <DataGrid Grid.Row="2"
                  x:Name="AliasGrid"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionUnit="Cell">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static resources:Strings.EditAlias_DeveloperColumn}"
                                    Binding="{Binding Developer}"
                                    IsReadOnly="True"
                                    Width="*" />
                <DataGridTemplateColumn Header="{x:Static resources:Strings.EditAlias_AliasColumn}"
                                        Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Alias}"
                                       VerticalAlignment="Center"
                                       Margin="4,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox IsEditable="True"
                                      StaysOpenOnEdit="True"
                                      Text="{Binding Alias, UpdateSourceTrigger=LostFocus}"
                                      ItemsSource="{Binding DataContext.AliasSuggestions, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="4">
            <Button Content="{x:Static resources:Strings.EditAlias_ResetButton}"
                    HorizontalAlignment="Left"
                    MinWidth="75"
                    Padding="8,0"
                    Click="ResetButton_Click"
                    ToolTip="{x:Static resources:Strings.EditAlias_ResetTooltip}" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="{x:Static resources:Strings.History_OkButton}"
                        Width="75"
                        Click="OkButton_Click"
                        IsDefault="True"
                        Margin="0,0,10,0" />
                <Button Content="{x:Static resources:Strings.History_CancelButton}"
                        Width="75"
                        Click="CancelButton_Click"
                        IsCancel="True" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
