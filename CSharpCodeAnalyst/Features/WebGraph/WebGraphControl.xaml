<UserControl x:Class="CSharpCodeAnalyst.Features.WebGraph.WebGraphControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:resources="clr-namespace:CSharpCodeAnalyst.Resources"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <!-- Bridges the WebView2 cold-start (~1-2 s on first app launch). The WebView2 is
             given a transparent default background in code-behind, so this placeholder shows
             through until the page paints; it is collapsed once the page reports "ready". -->
        <TextBlock x:Name="LoadingOverlay"
                   Text="{x:Static resources:Strings.WebView_Initializing}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="18" Foreground="#80868b" />
        <wv2:WebView2 x:Name="WebView" />
    </Grid>
</UserControl>
