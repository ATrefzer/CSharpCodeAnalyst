<UserControl x:Class="CSharpCodeAnalyst.Features.DsmMatrix.DsmMatrixView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:matrix="clr-namespace:DsmSuite.DsmViewer.View.Matrix;assembly=DsmSuite.DsmViewer.View"
             xmlns:userControls="clr-namespace:DsmSuite.DsmViewer.View.UserControls;assembly=DsmSuite.DsmViewer.View"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
        </Grid.RowDefinitions>

        <matrix:MatrixView x:Name="Matrix" Grid.Row="0" />
        <userControls:LegendView Grid.Row="1" />
    </Grid>
</UserControl>
