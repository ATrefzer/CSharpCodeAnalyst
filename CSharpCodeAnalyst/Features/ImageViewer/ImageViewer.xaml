<Window x:Class="CSharpCodeAnalyst.Features.ImageViewer.ImageViewer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:resources="clr-namespace:CSharpCodeAnalyst.Resources"
        mc:Ignorable="d"
        Title="{x:Static resources:Strings.ImageViewer_Title}" Height="400" Width="400">
    <Grid>
        <Image Name="_image" Margin="10"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Stretch="None" />
    </Grid>
</Window>