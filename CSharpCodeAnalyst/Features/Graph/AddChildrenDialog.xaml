<Window x:Class="CSharpCodeAnalyst.Features.Graph.AddChildrenDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:resources="clr-namespace:CSharpCodeAnalyst.Resources"
        xmlns:graph="clr-namespace:CSharpCodeAnalyst.Features.Graph"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance graph:AddChildrenDialogViewModel}"
        Title="{x:Static resources:Strings.AddDirectChildren_DialogTitle}"
        Height="450" Width="320"
        MinHeight="250" MinWidth="220"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox Grid.Row="0"
                 ItemsSource="{Binding Items}"
                 SelectionMode="Extended"
                 HorizontalContentAlignment="Stretch"
                 BorderBrush="LightGray" BorderThickness="1">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0"
                               VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{x:Static resources:Strings.Ok}" Width="75" Click="OkButton_Click"
                    Margin="0,0,10,0" IsDefault="True" />
            <Button Content="{x:Static resources:Strings.Cancel}" Width="75" Click="CancelButton_Click"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
