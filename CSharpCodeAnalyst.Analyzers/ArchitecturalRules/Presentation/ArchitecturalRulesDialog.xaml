<Window x:Class="CSharpCodeAnalyst.Analyzers.ArchitecturalRules.Presentation.ArchitecturalRulesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:resources="clr-namespace:CSharpCodeAnalyst.Analyzers.Resources"
        mc:Ignorable="d"
        Title="{x:Static resources:Strings.ArchitecturalRules_Title}"
        Height="600" Width="800"
        MinWidth="640" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" d:DataContext="{d:DesignInstance }">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/CSharpCodeAnalyst.AnalyzerSdk;component/Styles/ImageStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{x:Static resources:Strings.Rules_Header}"
                   FontSize="14" FontWeight="Bold" Margin="0,0,0,10" />

        <!-- Main text area -->
        <GroupBox Grid.Row="1" Header="{x:Static resources:Strings.Rules_RuleDefinition}" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <DockPanel Grid.Row="0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,5,0,5">
                    <Button x:Name="LoadFileButton" Content="{x:Static resources:Strings.Rules_LoadFromFile}"
                            Width="100"
                            Height="25" Margin="0,0,10,0"
                            Click="LoadFileButton_Click" />
                    <Button x:Name="SaveFileButton" Content="{x:Static resources:Strings.Rules_SaveToFile}"
                            Width="100" Height="25" Margin="0,0,10,0"
                            Click="SaveFileButton_Click" />
                    <Button x:Name="ClearButton" Content="{x:Static resources:Strings.Rules_Clear}"
                            Width="100" Height="25" Margin="0,0,10,0"
                            Click="ClearButton_Click" />
                    <Button x:Name="CopyCommandLineButton" Height="25"
                            ToolTip="{x:Static resources:Strings.Rules_CopyCommandLine_Tooltip}"
                            Click="CopyCommandLineButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/CSharpCodeAnalyst.AnalyzerSdk;component/Resources/clipboard_32.png"
                                   Width="16" Height="16" Margin="2,0,5,0" VerticalAlignment="Center" />
                            <TextBlock Text="{x:Static resources:Strings.Rules_CopyCommandLine}"
                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <Image Style="{StaticResource InfoStyle}" DockPanel.Dock="Right"
                       ToolTip="{x:Static resources:Strings.ArchitectureRules_Info}" />

                </DockPanel>
                <!-- Rules text box -->
                <TextBox Grid.Row="1" x:Name="RulesTextBox"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="#FAFAFA"
                         Text="{Binding RulesText, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </GroupBox>


        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="GenerateRulesButton" Content="{x:Static resources:Strings.Rules_Generate}"
                    Width="110" Height="25" Margin="0,0,10,0"
                    ToolTip="{x:Static resources:Strings.Rules_Generate_Tooltip}"
                    Click="GenerateRulesButton_Click" />
            <Button x:Name="RemoveUnusedRulesButton" Content="{x:Static resources:Strings.Rules_RemoveUnused}"
                    Width="130" Height="25" Margin="0,0,10,0"
                    ToolTip="{x:Static resources:Strings.Rules_RemoveUnused_Tooltip}"
                    Click="RemoveUnusedRulesButton_Click" />
            <Button x:Name="AcceptBaselineButton" Content="{x:Static resources:Strings.Rules_AcceptBaseline}"
                    Width="120" Height="25" Margin="0,0,10,0"
                    ToolTip="{x:Static resources:Strings.Rules_AcceptBaseline_Tooltip}"
                    IsEnabled="{Binding HasViolations}"
                    Click="AcceptBaselineButton_Click" />
            <Button x:Name="ValidateButton" Content="{x:Static resources:Strings.Validate}" Width="80" Height="25"
                    Margin="0,0,10,0" IsDefault="True"
                    Click="ValidateButton_Click" />
            <Button x:Name="CloseButton" Content="{x:Static resources:Strings.Close_Button}"  Height="25" Width="80"
                    IsCancel="True"
                    Click="CloseButton_Click" />
        </StackPanel>

        <!-- Result of the last validation, shown inline so feedback is visible even though the
             dialog is modeless and covers the result table behind it. -->
        <TextBlock Grid.Row="3" x:Name="StatusTextBlock" Text="{Binding StatusText}"
                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                   Margin="0,8,0,0" Foreground="#555555"
                   ToolTip="{Binding StatusText}" />
        
    </Grid>
</Window>