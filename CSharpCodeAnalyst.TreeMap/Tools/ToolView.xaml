<Window x:Class="CSharpCodeAnalyst.TreeMap.Tools.ToolView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tools="clr-namespace:CSharpCodeAnalyst.TreeMap.Tools"
        xmlns:resources="clr-namespace:CSharpCodeAnalyst.TreeMap.Resources"
        mc:Ignorable="d"
        Title="Tools"
        Height="365"
        Width="300"
        d:DataContext="{d:DesignInstance Type=tools:ToolViewModel, IsDesignTimeCreatable=False}"
        WindowStyle="ToolWindow" ResizeMode="NoResize" SizeToContent="Height">

    <Window.Resources>
        <!-- Slider used in every filter row; keeps snapping/delay in one place. -->
        <Style x:Key="FilterSlider" TargetType="Slider">
            <Setter Property="Delay" Value="200"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="Margin" Value="0 2 0 0"/>
        </Style>

        <!-- "Minimum" / "Maximum" caption on the left of a row. -->
        <Style x:Key="BoundLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- The current value, right aligned and slightly muted. -->
        <Style x:Key="BoundValue" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#666666"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="12">

        <TextBlock Text="{x:Static resources:Strings.HighlightPattern}"/>
        <TextBox Height="24" Margin="0 4 0 0"
                 Background="LightYellow"
                 VerticalContentAlignment="Center"
                 Text="{Binding SearchPattern, Delay=200, UpdateSourceTrigger=PropertyChanged}"/>

        <Separator Margin="0 12 0 8"/>

        <CheckBox Content="{x:Static resources:Strings.NoFilterJustHighlight}"
                  IsChecked="{Binding NoFilterJustHighlight}"/>

        <!-- Area filter: min / max as one labeled group. -->
        <GroupBox Header="{Binding AreaSemantic, Mode=OneWay}" Margin="0 12 0 0" Padding="8 4 8 8">
            <StackPanel>
                <DockPanel Margin="0 4 0 0">
                    <TextBlock Style="{StaticResource BoundLabel}" Text="{x:Static resources:Strings.Minimum}"/>
                    <TextBlock Style="{StaticResource BoundValue}" Text="{Binding MinArea, Mode=OneWay}"/>
                </DockPanel>
                <Slider Style="{StaticResource FilterSlider}"
                        Minimum="{Binding AreaIndexLower}" Maximum="{Binding AreaIndexUpper}"
                        Value="{Binding MinAreaIndex}"/>

                <DockPanel Margin="0 10 0 0">
                    <TextBlock Style="{StaticResource BoundLabel}" Text="{x:Static resources:Strings.Maximum}"/>
                    <TextBlock Style="{StaticResource BoundValue}" Text="{Binding MaxArea, Mode=OneWay}"/>
                </DockPanel>
                <Slider Style="{StaticResource FilterSlider}"
                        Minimum="{Binding AreaIndexLower}" Maximum="{Binding AreaIndexUpper}"
                        Value="{Binding MaxAreaIndex}"/>
            </StackPanel>
        </GroupBox>

        <!-- Weight filter: min / max as one labeled group. -->
        <GroupBox Header="{Binding WeightSemantic, Mode=OneWay}" Margin="0 10 0 0" Padding="8 4 8 8">
            <StackPanel>
                <DockPanel Margin="0 4 0 0">
                    <TextBlock Style="{StaticResource BoundLabel}" Text="{x:Static resources:Strings.Minimum}"/>
                    <TextBlock Style="{StaticResource BoundValue}" Text="{Binding MinWeight, Mode=OneWay}"/>
                </DockPanel>
                <Slider Style="{StaticResource FilterSlider}"
                        Minimum="{Binding WeightIndexLower}" Maximum="{Binding WeightIndexUpper}"
                        Value="{Binding MinWeightIndex}"/>

                <DockPanel Margin="0 10 0 0">
                    <TextBlock Style="{StaticResource BoundLabel}" Text="{x:Static resources:Strings.Maximum}"/>
                    <TextBlock Style="{StaticResource BoundValue}" Text="{Binding MaxWeight, Mode=OneWay}"/>
                </DockPanel>
                <Slider Style="{StaticResource FilterSlider}"
                        Minimum="{Binding WeightIndexLower}" Maximum="{Binding WeightIndexUpper}"
                        Value="{Binding MaxWeightIndex}"/>
            </StackPanel>
        </GroupBox>

        <!-- How raw weights are mapped onto the color ramp. -->
        <GroupBox Header="{x:Static resources:Strings.WeightColoring}" Margin="0 10 0 0" Padding="8 4 8 8">
            <ComboBox ItemsSource="{Binding WeightNormalizationOptions}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Strategy"
                      SelectedValue="{Binding WeightNormalization}"
                      Margin="0 4 0 0"/>
        </GroupBox>

        <Button Content="{x:Static resources:Strings.Reset}"
                Command="{Binding ResetCommand}"
                Width="100"
                HorizontalAlignment="Right"
                Margin="0 10 0 0"/>

    </StackPanel>
</Window>